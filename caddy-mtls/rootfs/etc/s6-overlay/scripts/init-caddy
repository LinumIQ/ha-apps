#!/command/with-contenv bashio
# ==============================================================================
# Home Assistant Add-on: Caddy mTLS Proxy
# Init oneshot: validate config, ensure CA + server certs, seed clients on
# first boot from `client_names`, refresh /data/state.json metadata, render
# the Caddyfile, generate the CRL, populate the active-cert allowlist.
# ==============================================================================
set -e

# shellcheck source=rootfs/etc/s6-overlay/scripts/lib/cert-helpers.sh
source /etc/s6-overlay/scripts/lib/cert-helpers.sh
# shellcheck source=rootfs/etc/s6-overlay/scripts/lib/state.sh
source /etc/s6-overlay/scripts/lib/state.sh

###############################################################################
# Paths (also referenced by the Caddyfile)
###############################################################################
readonly CERT_DIR="/data/certs"
readonly CADDY_DATA="/data/caddy"
readonly CADDYFILE="/etc/caddy/Caddyfile"

mkdir -p "${CERT_DIR}" "${CADDY_DATA}"
chmod 700 "${CERT_DIR}"

###############################################################################
# Read configuration
###############################################################################
bashio::log.info "Reading configuration..."

DOMAIN="$(bashio::config 'domain')"
EMAIL="$(bashio::config 'email')"
UPSTREAM_HOST="$(bashio::config 'upstream_host')"
UPSTREAM_PORT="$(bashio::config 'upstream_port')"
MTLS_ENABLED="$(bashio::config 'mtls_enabled')"

CA_COUNTRY="$(bashio::config 'ca_country')"
CA_STATE="$(bashio::config 'ca_state')"
CA_LOCALITY="$(bashio::config 'ca_locality')"
CA_ORGANIZATION="$(bashio::config 'ca_organization')"
CA_COMMON_NAME="$(bashio::config 'ca_common_name')"

CLIENT_CERT_PASSWORD="$(bashio::config 'client_cert_password')"

ACME_DNS_PROVIDER="$(bashio::config 'acme_dns_provider')"
DNS_API_TOKEN="$(bashio::config 'dns_api_token')"
LOG_LEVEL="$(bashio::config 'log_level' 'info')"

# Required by the helper functions and the cert-mgr / cert-monitor services.
export CERT_DIR DOMAIN \
       CA_COUNTRY CA_STATE CA_LOCALITY CA_ORGANIZATION CA_COMMON_NAME \
       CLIENT_CERT_PASSWORD

###############################################################################
# Validation
###############################################################################
if bashio::var.is_empty "${DOMAIN}"; then
    bashio::exit.nok "Option 'domain' is required (e.g. home.example.com)."
fi

if bashio::var.is_empty "${EMAIL}"; then
    bashio::exit.nok "Option 'email' is required for Let's Encrypt registration."
fi

case "${ACME_DNS_PROVIDER}" in
    none|cloudflare|route53|hetzner) ;;
    *) bashio::exit.nok "Unknown acme_dns_provider '${ACME_DNS_PROVIDER}'." ;;
esac

if [[ "${ACME_DNS_PROVIDER}" != "none" ]] && bashio::var.is_empty "${DNS_API_TOKEN}"; then
    bashio::exit.nok "DNS API token is required when acme_dns_provider is '${ACME_DNS_PROVIDER}'."
fi

if bashio::var.true "${MTLS_ENABLED}" && bashio::var.is_empty "${CLIENT_CERT_PASSWORD}"; then
    bashio::exit.nok "client_cert_password must be set when mTLS is enabled."
fi

###############################################################################
# Initialise state file (atomic, idempotent)
###############################################################################
state_init

# Detect first boot for client seeding (no clients tracked yet).
FIRST_BOOT_CLIENTS=0
if [[ "$(jq -r '(.clients // []) | length' "${STATE_FILE}")" == "0" ]]; then
    FIRST_BOOT_CLIENTS=1
fi

###############################################################################
# Generate certificates if mTLS is enabled
###############################################################################
if bashio::var.true "${MTLS_ENABLED}"; then
    bashio::log.info "mTLS is enabled, ensuring certificates are present..."

    if [[ ! -f "${CERT_DIR}/mTLS-CA.crt" ]]; then
        bashio::log.info "Generating CA certificate..."
        generate_ca
    else
        bashio::log.info "Reusing existing CA certificate."
        init_ca_db
    fi

    state_refresh_ca

    if [[ "${FIRST_BOOT_CLIENTS}" == "1" ]]; then
        bashio::log.info "First boot detected: seeding clients from 'client_names' option..."
        while IFS= read -r client_name; do
            [[ -z "${client_name}" ]] && continue
            if [[ ! -f "${CERT_DIR}/mTLS-client-${client_name}.p12" ]]; then
                bashio::log.info "Generating client certificate for: ${client_name}"
                generate_client_cert "${client_name}"
            else
                bashio::log.info "Reusing existing client certificate for: ${client_name}"
            fi
            state_refresh_client "${client_name}"
        done < <(bashio::jq "/data/options.json" '.client_names[]?')
    else
        bashio::log.info "Refreshing metadata for tracked clients..."
        while IFS= read -r client_name; do
            [[ -z "${client_name}" ]] && continue
            state_refresh_client "${client_name}"
        done < <(state_all_clients)
    fi
fi

###############################################################################
# Populate active client cert directory + (re)generate CRL
###############################################################################
if bashio::var.true "${MTLS_ENABLED}"; then
    bashio::log.info "Populating active client cert allowlist..."
    # shellcheck disable=SC2046
    populate_active_dir $(state_active_clients | tr '\n' ' ')

    bashio::log.info "Generating CRL..."
    generate_crl
    state_refresh_crl
fi

###############################################################################
# Render Caddyfile
###############################################################################
bashio::log.info "Rendering Caddyfile..."

# Map bashio log levels onto Caddy log levels.
case "${LOG_LEVEL}" in
    trace|debug)            CADDY_LOG_LEVEL="DEBUG" ;;
    info|notice)            CADDY_LOG_LEVEL="INFO" ;;
    warning)                CADDY_LOG_LEVEL="WARN" ;;
    error|fatal)            CADDY_LOG_LEVEL="ERROR" ;;
    *)                      CADDY_LOG_LEVEL="INFO" ;;
esac

TLS_DIRECTIVES=""
if [[ "${ACME_DNS_PROVIDER}" != "none" ]]; then
    # Pass the secret via environment variable referenced through Caddy's
    # {env.X} placeholder so that the token never lands in the on-disk
    # Caddyfile and cannot break the Caddyfile syntax.
    export DNS_API_TOKEN
    TLS_DIRECTIVES="${TLS_DIRECTIVES}        dns ${ACME_DNS_PROVIDER} {env.DNS_API_TOKEN}
"
fi

if bashio::var.true "${MTLS_ENABLED}"; then
    TLS_DIRECTIVES="${TLS_DIRECTIVES}        client_auth {
            mode require_and_verify
            trust_pool file {
                pem_file ${CERT_DIR}/mTLS-CA.crt
            }
            verifier leaf {
                folder ${CERT_DIR}/active
            }
        }
"
fi

# Caddy rejects an empty 'tls { }' block. Only emit it when we have
# directives to put inside; otherwise omit it entirely so Caddy falls back
# to fully automatic HTTPS (HTTP-01 / TLS-ALPN challenges).
TLS_BLOCK=""
if [[ -n "${TLS_DIRECTIVES}" ]]; then
    TLS_BLOCK="tls {
${TLS_DIRECTIVES}    }"
fi

# Plain-HTTP CRL site. Only emitted when mTLS (and therefore the CRL) is
# enabled. Caddy still serves the ACME HTTP-01 challenge on this listener
# automatically; user routes only run for non-challenge requests.
CRL_SITE=""
if bashio::var.true "${MTLS_ENABLED}"; then
    CRL_SITE="
http://${DOMAIN} {
    @crl path /mTLS-CA.crl
    handle @crl {
        root * ${CERT_DIR}
        file_server
    }
    # Anything other than the public CRL endpoint is redirected to HTTPS.
    # ACME HTTP-01 challenges are still handled automatically by Caddy
    # before user routes, so this redirect does not break cert renewal.
    handle {
        redir https://{host}{uri} permanent
    }

    log {
        output stdout
        format console
        level ${CADDY_LOG_LEVEL}
    }
}
"
fi

cat > "${CADDYFILE}" <<CADDYFILE
# Caddy mTLS Proxy - generated by init-caddy on every start. Do not edit.

{
    email ${EMAIL}

    storage file_system {
        root ${CADDY_DATA}
    }

    # Loopback-only admin API so cert-mgr can reload Caddy in-place.
    admin localhost:2019

    log default {
        output stdout
        format console
        level ${CADDY_LOG_LEVEL}
    }
}

# Public mTLS-protected reverse proxy
${DOMAIN} {
    ${TLS_BLOCK}

    reverse_proxy ${UPSTREAM_HOST}:${UPSTREAM_PORT} {
        header_up X-Real-IP {remote_host}
    }

    log {
        output stdout
        format console
        level ${CADDY_LOG_LEVEL}
    }
}
${CRL_SITE}
CADDYFILE

bashio::log.info "Validating generated Caddyfile..."
if ! /usr/bin/caddy validate --config "${CADDYFILE}" --adapter caddyfile; then
    bashio::exit.nok "Generated Caddyfile failed validation"
fi

###############################################################################
# Mirror certs to /config for user access via the Samba/SSH/file editor add-ons.
###############################################################################
if bashio::var.true "${MTLS_ENABLED}" && [[ -d "/config" ]]; then
    bashio::log.info "Mirroring certificates to /config/certs..."
    mkdir -p /config/certs
    chmod 700 /config/certs

    if ! cp "${CERT_DIR}/mTLS-CA.crt" /config/certs/; then
        bashio::log.warning "Could not copy CA cert to /config/certs"
    else
        chmod 644 /config/certs/mTLS-CA.crt
    fi

    if [[ -f "${CERT_DIR}/mTLS-CA.crl" ]]; then
        cp "${CERT_DIR}/mTLS-CA.crl" /config/certs/ 2>/dev/null || true
        chmod 644 /config/certs/mTLS-CA.crl 2>/dev/null || true
    fi

    while IFS= read -r client_name; do
        [[ -z "${client_name}" ]] && continue
        src="${CERT_DIR}/mTLS-client-${client_name}.p12"
        dst="/config/certs/mTLS-client-${client_name}.p12"
        if [[ -f "${src}" ]] && cp "${src}" "${dst}"; then
            chmod 600 "${dst}"
        elif [[ -f "${src}" ]]; then
            bashio::log.warning "Could not copy '${src}' to /config/certs"
        fi
    done < <(state_active_clients)
fi

###############################################################################
# Done
###############################################################################
bashio::log.info "Init complete:"
bashio::log.info "  Domain:      ${DOMAIN}"
bashio::log.info "  Upstream:    ${UPSTREAM_HOST}:${UPSTREAM_PORT}"
bashio::log.info "  mTLS:        ${MTLS_ENABLED}"
bashio::log.info "  ACME DNS:    ${ACME_DNS_PROVIDER}"
bashio::log.info "  Log level:   ${LOG_LEVEL} (caddy=${CADDY_LOG_LEVEL})"

###############################################################################
# Reverse-proxy reminder for Home Assistant Core.
# HA Core rejects requests from unknown reverse proxies with 400 Bad Request.
# We can't edit the user's configuration.yaml safely, so emit a prominent,
# copy-pasteable reminder on every start. Detect our own container IP so the
# user can also whitelist a single address if they prefer it over the whole
# Supervisor docker subnet.
###############################################################################
ADDON_IP="$(hostname -i 2>/dev/null | awk '{print $1}')"
[[ -z "${ADDON_IP}" ]] && ADDON_IP="<this add-on's container IP>"

bashio::log.notice "------------------------------------------------------------"
bashio::log.notice "Home Assistant Core must trust this add-on as a reverse"
bashio::log.notice "proxy, otherwise it returns 400 Bad Request for every"
bashio::log.notice "request forwarded through ${DOMAIN}."
bashio::log.notice ""
bashio::log.notice "Add this to /config/configuration.yaml and restart HA Core:"
bashio::log.notice ""
bashio::log.notice "  http:"
bashio::log.notice "    use_x_forwarded_for: true"
bashio::log.notice "    trusted_proxies:"
bashio::log.notice "      - 172.30.32.0/23   # Supervisor docker network"
bashio::log.notice "      # or just this add-on's current IP: ${ADDON_IP}"
bashio::log.notice ""
bashio::log.notice "See the add-on documentation for details."
bashio::log.notice "------------------------------------------------------------"
